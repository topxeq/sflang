// S3 兼容对象存储客户端示例
// 用法：sf examples/showcase/s3_demo.sf
//
// 演示 S3 内置函数的典型用法：
//   1. 创建客户端（MinIO 风格 + AWS 风格）
//   2. Bucket 操作（创建/检查/列举）
//   3. Object 读写（字符串/bytes/byteArray）
//   4. 文件上传下载
//   5. 对象管理（列表/删除/拷贝/属性）

// ============================================================
// 1. 创建客户端
// ============================================================

// MinIO 风格（path-style 自动推断：非 80/443 端口 → path-style=true）
var minioClient = s3Connect("http://localhost:9000", "us-east-1",
    "minioadmin", "minioadmin")
if isErr(minioClient) {
    print("连接 MinIO 失败:", minioClient)
    return
}
print("1. MinIO 客户端创建成功, 类型:", typeName(minioClient))

// AWS S3 风格（virtual-hosted-style 自动推断：amazonaws.com → path-style=false）
// 注意：实际使用需替换为真实 AK/SK
// var awsClient = s3Connect("https://s3.us-east-1.amazonaws.com", "us-east-1",
//     "YOUR_AK", "YOUR_SK")

// 显式指定 path-style（第 5 个参数）
var explicitClient = s3Connect("https://s3.us-east-1.amazonaws.com", "us-east-1",
    "ak", "sk", true)
print("   显式 path-style 客户端:", typeName(explicitClient))

