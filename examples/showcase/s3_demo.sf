// ============================================================
// 7. 关闭客户端（无实际资源，仅规范）
// ============================================================
s3Close(minioClient)
print("7. 客户端已关闭")

print("\n示例完成")
print("注意：本示例仅展示 API 用法，实际执行需配置真实 S3 服务")
