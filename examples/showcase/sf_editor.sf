html = html + "</div>"

// 状态栏
html = html + "<div class='statusbar'>"
html = html + "<span id='status'>就绪</span>"
html = html + "<span class='spacer'></span>"
html = html + "<span id='cursorInfo'>行 1, 列 1</span>"
html = html + "<span id='unicodeInfo'>U+0000</span>"
html = html + "<span id='encodingInfo' style='cursor:pointer' onclick='cycleEncoding()' title='点击切换编码'>UTF-8</span>"
html = html + "<span id='lineEndingInfo' style='cursor:pointer' onclick='cycleLineEnding()' title='点击切换换行符'>LF</span>"
html = html + "<span>Sflang</span>"
html = html + "</div>"

html = html + "</body>"

// ---- JavaScript ----
html = html + "<script>"

// Sflang 关键字
html = html + "var KEYWORDS = ['var','const','func','if','elif','else','for','while','switch','case','default','break','continue','return','try','catch','finally','defer','run','throw','import','in'];"
html = html + "var BOOLS = ['true','false','undefined'];"

// 语法高亮函数
html = html + "function highlightCode(code) {"
html = html + "  var html = '';"
html = html + "  var i = 0;"
html = html + "  while (i < code.length) {"
html = html + "    var c = code[i];"
// 注释 //
html = html + "    if (c == '/' && code[i+1] == '/') {"
html = html + "      var end = code.indexOf('\\n', i);"
html = html + "      if (end < 0) end = code.length;"
html = html + "      html += '<span class=\\'cmt\\'>' + esc(code.substring(i, end)) + '</span>';"
html = html + "      i = end; continue;"
html = html + "    }"
// 注释 /* */
html = html + "    if (c == '/' && code[i+1] == '*') {"
html = html + "      var end = code.indexOf('*/', i+2);"
html = html + "      if (end < 0) end = code.length; else end += 2;"
html = html + "      html += '<span class=\\'cmt\\'>' + esc(code.substring(i, end)) + '</span>';"
html = html + "      i = end; continue;"
html = html + "    }"
// 字符串 "..."（含三引号）
html = html + "    if (c == '\"') {"
html = html + "      if (code[i+1] == '\"' && code[i+2] == '\"') {"
html = html + "        var end = code.indexOf('\\\"\\\"\\\"', i+3);"
html = html + "        if (end < 0) end = code.length; else end += 3;"
html = html + "      } else {"
html = html + "        var end = i+1;"
html = html + "        while (end < code.length && code[end] != '\\n') {"
html = html + "          if (code[end] == '\\\\') { end += 2; } else if (code[end] == '\"') { end++; break; } else end++;"
html = html + "        }"
html = html + "      }"
html = html + "      html += '<span class=\\'str\\'>' + esc(code.substring(i, end)) + '</span>';"
html = html + "      i = end; continue;"
html = html + "    }"
// Raw string `...`
html = html + "    if (c == '`') {"
html = html + "      var end = code.indexOf('`', i+1);"
html = html + "      if (end < 0) end = code.length; else end++;"
html = html + "      html += '<span class=\\'str\\'>' + esc(code.substring(i, end)) + '</span>';"
html = html + "      i = end; continue;"
html = html + "    }"
// 数字
html = html + "    if (c >= '0' && c <= '9') {"
html = html + "      var end = i;"
html = html + "      while (end < code.length && /[0-9a-fA-FxXoObB._]/.test(code[end])) end++;"
html = html + "      html += '<span class=\\'num\\'>' + code.substring(i, end) + '</span>';"
html = html + "      i = end; continue;"
html = html + "    }"
// 标识符/关键字
html = html + "    if (/[a-zA-Z_$]/.test(c)) {"
html = html + "      var end = i;"
html = html + "      while (end < code.length && /[a-zA-Z0-9_$]/.test(code[end])) end++;"
html = html + "      var word = code.substring(i, end);"
html = html + "      if (KEYWORDS.indexOf(word) >= 0) html += '<span class=\\'kw\\'>' + word + '</span>';"
html = html + "      else if (BOOLS.indexOf(word) >= 0) html += '<span class=\\'bool\\'>' + word + '</span>';"
html = html + "      else if (code[end] == '(') html += '<span class=\\'fn\\'>' + word + '</span>';"
html = html + "      else html += esc(word);"
html = html + "      i = end; continue;"
html = html + "    }"
// 换行
html = html + "    if (c == '\\n') { html += '\\n'; i++; continue; }"
html = html + "    if (c == '<') { html += '&lt;'; i++; continue; }"
html = html + "    if (c == '>') { html += '&gt;'; i++; continue; }"
html = html + "    if (c == '&') { html += '&amp;'; i++; continue; }"
html = html + "    html += c; i++;"
html = html + "  }"
html = html + "  return html;"
html = html + "}"

// HTML 转义
html = html + "function esc(s) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }"

// 编辑器事件
html = html + "var isDirty = false; var currentFile = ''; var fileEncoding = 'UTF-8'; var lineEnding = 'LF';"
html = html + "function setDirty(v) { isDirty = v; updateTitle(); }"
html = html + "function updateTitle() {"
html = html + "  var fn = document.getElementById('filename');"
html = html + "  fn.textContent = (currentFile || '未命名.sf') + (isDirty ? ' ●' : '');"
html = html + "}"

html = html + "function updateGutter() {"
html = html + "  var ta = document.getElementById('editor');"
html = html + "  var codeLines = ta.value.split('\\n');"
html = html + "  var n = codeLines.length;"
html = html + "  if (!wordWrap) {"
html = html + "    var nums = ''; for (var i = 1; i <= n; i++) nums += i + '\\n';"
html = html + "    document.getElementById('gutter').textContent = nums;"
html = html + "    return;"
html = html + "  }"
html = html + "  var gutter = document.getElementById('gutter');"
html = html + "  gutter.textContent = '';"
html = html + "  var taInner = ta.clientWidth - 36;"
html = html + "  var cw = 8.4;"
html = html + "  for (var i = 0; i < n; i++) {"
html = html + "    var d = document.createElement('div');"
html = html + "    d.textContent = (i+1);"
html = html + "    var rows = Math.max(1, Math.ceil((codeLines[i].length * cw) / taInner));"
html = html + "    d.style.height = (rows * 21) + 'px';"
html = html + "    d.style.lineHeight = '21px';"
html = html + "    gutter.appendChild(d);"
html = html + "  }"
html = html + "}"

html = html + "function onEdit() {"
html = html + "  var ta = document.getElementById('editor');"
html = html + "  var code = ta.value;"
html = html + "  if (code[code.length-1] == '\\n') code += ' ';"
html = html + "  document.getElementById('highlight').innerHTML = highlightCode(code);"
html = html + "  updateGutter();"
html = html + "  updateCursor();"
html = html + "  setDirty(true);"
html = html + "}"

// 同步滚动
html = html + "function onScroll() {"
html = html + "  var ta = document.getElementById('editor');"
html = html + "  document.getElementById('highlight').scrollTop = ta.scrollTop;"
html = html + "  document.getElementById('highlight').scrollLeft = ta.scrollLeft;"
html = html + "  document.getElementById('gutter').scrollTop = ta.scrollTop;"
html = html + "}"

// 更新光标位置 + Unicode 码点
html = html + "function updateCursor() {"
html = html + "  var ta = document.getElementById('editor');"
html = html + "  var pos = ta.selectionStart;"
html = html + "  var before = ta.value.substring(0, pos);"
html = html + "  var lines = before.split('\\n');"
html = html + "  document.getElementById('cursorInfo').textContent = '行 ' + lines.length + ', 列 ' + (lines[lines.length-1].length+1);"
html = html + "  var ch = ta.value.substring(pos, pos+1);"
html = html + "  if (ch) {"
html = html + "    var cp = ch.codePointAt(0);"
html = html + "    var hex = cp.toString(16).toUpperCase().padStart(4, '0');"
html = html + "    document.getElementById('unicodeInfo').textContent = 'U+' + hex + ' ' + ch;"
html = html + "  } else { document.getElementById('unicodeInfo').textContent = 'EOF'; }"
html = html + "}"

// 编码切换
html = html + "var encodings = ['UTF-8', 'GBK']; var encIdx = 0;"
html = html + "function cycleEncoding() {"
html = html + "  encIdx = (encIdx + 1) % encodings.length;"
html = html + "  fileEncoding = encodings[encIdx];"
html = html + "  document.getElementById('encodingInfo').textContent = fileEncoding;"
html = html + "  document.getElementById('status').textContent = '编码: ' + fileEncoding + '（保存时生效）';"
html = html + "}"

// 换行符切换
html = html + "var lineEndings = ['LF', 'CRLF']; var leIdx = 0;"
html = html + "function cycleLineEnding() {"
html = html + "  leIdx = (leIdx + 1) % lineEndings.length;"
html = html + "  lineEnding = lineEndings[leIdx];"
html = html + "  document.getElementById('lineEndingInfo').textContent = lineEnding;"
html = html + "  document.getElementById('status').textContent = '换行符: ' + lineEnding + '（保存时生效）';"
html = html + "}"

// 键盘快捷键
html = html + "function onKey(e) {"
html = html + "  if (e.key == 'F5') { e.preventDefault(); doRun(); }"
html = html + "  else if (e.key == 'F6') { e.preventDefault(); doEval(); }"
html = html + "  else if (e.key == 'F7') { e.preventDefault(); doCmdRun(); }"
html = html + "  else if (e.ctrlKey && e.shiftKey && e.key == 'S') { e.preventDefault(); doSaveAs(); }"
html = html + "  else if (e.ctrlKey && e.key == 's') { e.preventDefault(); doSave(); }"
html = html + "  else if (e.ctrlKey && e.key == 'o') { e.preventDefault(); doOpen(); }"
html = html + "  else if (e.ctrlKey && e.key == 'n') { e.preventDefault(); doNew(); }"
html = html + "  else if (e.key == 'Tab') { e.preventDefault(); document.execCommand('insertText', false, '    '); }"
html = html + "}"

// 运行（子进程）
html = html + "function doRun() {"
html = html + "  var code = document.getElementById('editor').value;"
html = html + "  document.getElementById('status').textContent = '运行中...';"
html = html + "  window.ipc.postMessage('RUN\\n' + code);"
html = html + "}"

// 快速求值（进程内）
html = html + "function doEval() {"
html = html + "  var code = document.getElementById('editor').value;"
html = html + "  document.getElementById('status').textContent = '求值中...';"
html = html + "  window.ipc.postMessage('EVAL\\n' + code);"
html = html + "}"

// CMD 窗口运行
html = html + "function doCmdRun() {"
html = html + "  var code = document.getElementById('editor').value;"
html = html + "  document.getElementById('status').textContent = 'CMD 运行中...';"
html = html + "  window.ipc.postMessage('CMDRUN\\n' + code);"
html = html + "}"

// 新建文件
html = html + "function doNew() {"
html = html + "  if (isDirty && !confirm('当前文件未保存，是否放弃修改？')) return;"
html = html + "  document.getElementById('editor').value = '';"
html = html + "  onEdit();"
html = html + "  currentFile = '';"
html = html + "  setDirty(false);"
html = html + "  clearOutput();"
html = html + "  document.getElementById('status').textContent = '就绪';"
html = html + "  document.getElementById('editor').focus();"
html = html + "}"

// 打开文件（用原生系统对话框，通过 IPC 调 Sflang 后端）
html = html + "function doOpen() {"
html = html + "  if (isDirty && !confirm('当前文件未保存，是否放弃修改？')) return;"
html = html + "  document.getElementById('status').textContent = '请选择文件...';"
html = html + "  window.ipc.postMessage('OPENDLG');"
html = html + "}"

// 保存文件（有当前路径时直接保存，否则弹保存对话框）
html = html + "function doSave() {"
html = html + "  if (currentFile) { saveToPath(currentFile); }"
html = html + "  else { doSaveAs(); }"
html = html + "}"

// 另存为（弹原生保存对话框）
html = html + "function doSaveAs() {"
html = html + "  document.getElementById('status').textContent = '请选择保存位置...';"
html = html + "  var defaultName = currentFile ? currentFile.split('/').pop().split('\\\\').pop() : 'untitled.sf';"
html = html + "  window.ipc.postMessage('SAVEDLG' + String.fromCharCode(10) + defaultName);"
html = html + "}"
html = html + "function saveToPath(path) {"
html = html + "  var code = document.getElementById('editor').value;"
html = html + "  window.ipc.postMessage('SAVE' + String.fromCharCode(10) + path + String.fromCharCode(10) + fileEncoding + String.fromCharCode(10) + lineEnding + String.fromCharCode(10) + code);"
html = html + "}"

// 清空输出
html = html + "function clearOutput() {"
html = html + "  document.getElementById('output').innerHTML = '';"
html = html + "  document.getElementById('output').className = 'output-content';"
html = html + "}"

// 显示输出（供 Sflang 后端调用）
html = html + "function showOutput(text, isError) {"
html = html + "  var el = document.getElementById('output');"
html = html + "  el.className = 'output-content' + (isError ? ' error' : '');"
html = html + "  el.textContent = text;"
html = html + "}"

// 设置编辑器内容（打开文件时）
html = html + "function setEditorContent(code) {"
html = html + "  document.getElementById('editor').value = code;"
html = html + "  onEdit();"
html = html + "  setDirty(false);"
html = html + "}"

// 设置文件名（打开/保存后调用）
html = html + "function setFileName(name) {"
html = html + "  currentFile = name;"
html = html + "  setDirty(false);"
html = html + "}"

// 设置状态
html = html + "function setStatus(text) {"
html = html + "  document.getElementById('status').textContent = text;"
html = html + "}"

// 切换折行
html = html + "var wordWrap = true;"
html = html + "function toggleWrap() {"
html = html + "  wordWrap = !wordWrap;"
html = html + "  var ta = document.getElementById('editor');"
html = html + "  var hl = document.getElementById('highlight');"
html = html + "  if (wordWrap) {"
html = html + "    ta.style.whiteSpace = 'pre-wrap'; ta.style.wordWrap = 'break-word';"
html = html + "    hl.style.whiteSpace = 'pre-wrap'; hl.style.wordWrap = 'break-word';"
html = html + "  } else {"
html = html + "    ta.style.whiteSpace = 'pre'; ta.style.wordWrap = 'normal';"
html = html + "    hl.style.whiteSpace = 'pre'; hl.style.wordWrap = 'normal';"
html = html + "  }"
html = html + "  document.getElementById('wrapBtn').style.background = wordWrap ? '#264f78' : '#3c3c3c';"
html = html + "  onEdit();"
html = html + "}"

// 切换主题（简易：切换输出区高度）
html = html + "var bigOutput = false;"
html = html + "function toggleTheme() {"
html = html + "  bigOutput = !bigOutput;"
html = html + "  document.getElementById('outputArea').style.height = bigOutput ? '50%' : '220px';"
html = html + "}"

// 插入示例代码
// 模板下拉菜单
html = html + "function toggleTplMenu() {"
html = html + "  var m = document.getElementById('tplMenu');"
html = html + "  m.style.display = m.style.display == 'none' ? 'block' : 'none';"
html = html + "}"
html = html + "document.addEventListener('click', function(e) {"
html = html + "  if (!e.target.closest('.tpl-item') && !e.target.matches('[onclick*=toggleTplMenu]'))"
html = html + "    document.getElementById('tplMenu').style.display = 'none';"
html = html + "});"

html = html + "var TEMPLATES = {};"
html = html + "function loadTplFile(path, name) {"
html = html + "  window.ipc.postMessage('OPEN\\n' + path);"
html = html + "}"

html = html + "function loadTpl(name) {"
html = html + "  var hasContent = document.getElementById('editor').value.trim().length > 0;"
html = html + "  if (hasContent && isDirty && !confirm('当前内容未保存，是否替换？')) return;"
html = html + "  document.getElementById('tplMenu').style.display = 'none';"
html = html + "  document.getElementById('status').textContent = '加载模板中: ' + name;"
html = html + "  var msg = 'TPL' + String.fromCharCode(10) + name;"
html = html + "  window.ipc.postMessage(msg);"
html = html + "}"

// 初始化
html = html + "window.onload = function() {"
html = html + "  toggleWrap(); toggleWrap();"
html = html + "  onEdit();"
html = html + "  setDirty(false);"
html = html + "  document.getElementById('editor').focus();"
html = html + "};"

// 全局错误捕获——显示在输出区
html = html + "window.onerror = function(msg, url, line, col, err) {"
html = html + "  var el = document.getElementById('output');"
html = html + "  el.className = 'output-content error';"
html = html + "  el.textContent = '[JS错误] ' + msg + ' (行' + line + ':' + col + ')';"
html = html + "  return true;"
html = html + "};"

html = html + "</script></html>"

// ---- 创建窗口 ----
var win = guiNewWindow("--title=Sflang 代码编辑器", "--width=1100", "--height=750")
win = guiSetHtml(win, html)
win = guiSetHandler(win, onMessage)

// 如果有命令行参数指定的文件，加载它
if initFile != "" && fileExists(initFile) {
    var initContent = readFile(initFile)
    // 延迟执行：在 guiShow 之前无法执行 guiEval，所以通过初始 HTML 内嵌
    // 改为在 HTML 的 onload 中检查全局变量
    // 简单方案：把初始内容编码到 HTML 中
    html = strReplace(html, "window.onload = function() {",
        "window.onload = function() { document.getElementById('editor').value = '" + escapeJS(initContent) + "'; document.getElementById('filename').textContent = '" + escapeJS(initFile) + "';")
    win = guiSetHtml(win, html)
}

guiShow(win)
