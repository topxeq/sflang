html = html + "function showLangRef(html) {"
html = html + "  var overlay = document.createElement('div');"
html = html + "  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.7);z-index:1000;display:flex;';"
html = html + "  var dlg = document.createElement('div');"
html = html + "  dlg.style.cssText = 'background:#1e1e1e;color:#d4d4d4;border-radius:8px;margin:auto;width:90vw;max-width:1200px;height:90vh;display:flex;flex-direction:column;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,0.5);';"
html = html + "  var header = document.createElement('div');"
html = html + "  header.style.cssText = 'display:flex;align-items:center;padding:10px 16px;border-bottom:1px solid #3c3c3c;flex-shrink:0;';"
html = html + "  var title = document.createElement('span');"
html = html + "  title.textContent = 'Sflang 语言参考';"
html = html + "  title.style.cssText = 'font-size:15px;font-weight:bold;color:#4ec9b0;';"
html = html + "  header.appendChild(title);"
html = html + "  var search = document.createElement('input');"
html = html + "  search.type = 'text';"
html = html + "  search.placeholder = '搜索目录...';"
html = html + "  search.style.cssText = 'margin-left:16px;flex:1;background:#2d2d2d;border:1px solid #505050;border-radius:3px;padding:4px 10px;color:#d4d4d4;font-size:13px;outline:none;';"
html = html + "  header.appendChild(search);"
html = html + "  var closeBtn = document.createElement('button');"
html = html + "  closeBtn.textContent = 'X';"
html = html + "  closeBtn.style.cssText = 'margin-left:12px;background:#f44747;color:#fff;border:none;border-radius:3px;width:28px;height:28px;cursor:pointer;font-size:14px;';"
html = html + "  closeBtn.onclick = function() { document.body.removeChild(overlay); };"
html = html + "  header.appendChild(closeBtn);"
html = html + "  dlg.appendChild(header);"
html = html + "  var body = document.createElement('div');"
html = html + "  body.style.cssText = 'flex:1;display:flex;overflow:hidden;';"
html = html + "  var toc = document.createElement('div');"
html = html + "  toc.style.cssText = 'width:220px;overflow-y:auto;padding:8px 0;border-right:1px solid #3c3c3c;flex-shrink:0;';"
html = html + "  var content = document.createElement('div');"
html = html + "  content.style.cssText = 'flex:1;overflow-y:auto;padding:16px 24px;font-size:14px;line-height:1.7;';"
html = html + "  content.innerHTML = html;"
html = html + "  body.appendChild(toc);"
html = html + "  body.appendChild(content);"
html = html + "  dlg.appendChild(body);"
html = html + "  overlay.appendChild(dlg);"
html = html + "  overlay.onclick = function(e) { if (e.target == overlay) document.body.removeChild(overlay); };"
html = html + "  document.body.appendChild(overlay);"
html = html + "  content.style.cssText += 'h2{color:#569cd6;border-bottom:1px solid #3c3c3c;padding-bottom:4px;margin-top:24px;} h3{color:#4ec9b0;margin-top:16px;} table{border-collapse:collapse;width:100%;margin:8px 0;} th,td{border:1px solid #555;padding:4px 10px;text-align:left;} th{background:#2d2d2d;} code{background:#2d2d2d;padding:1px 5px;border-radius:3px;font-size:13px;color:#ce9178;} pre{background:#1a1a1a;border:1px solid #3c3c3c;border-radius:4px;padding:10px;overflow-x:auto;} pre code{background:none;color:#d4d4d4;} a{color:#3794ff;}';"
html = html + "  var headings = content.querySelectorAll('h2,h3');"
html = html + "  var tocItems = [];"
html = html + "  for (var i = 0; i < headings.length; i++) { (function(h, idx) {"
html = html + "    var id = 'sec-' + idx;"
html = html + "    h.id = id;"
html = html + "    var item = document.createElement('div');"
html = html + "    item.textContent = h.textContent;"
html = html + "    item.style.cssText = 'padding:3px 12px;cursor:pointer;font-size:13px;color:#aaa;border-radius:3px;'"
html = html + "      + (h.tagName == 'H3' ? 'padding-left:28px;font-size:12px;' : 'font-weight:bold;color:#d4d4d4;');"
html = html + "    item.onmouseover = function() { item.style.background = '#264f78'; };"
html = html + "    item.onmouseout = function() { item.style.background = ''; };"
html = html + "    item.onclick = function() { h.scrollIntoView({behavior:'smooth',block:'start'}); };"
html = html + "    toc.appendChild(item);"
html = html + "    tocItems.push({el: item, text: h.textContent.toLowerCase()});"
html = html + "  })(headings[i], i); }"
html = html + "  search.oninput = function() {"
html = html + "    var q = search.value.toLowerCase();"
html = html + "    for (var i = 0; i < tocItems.length; i++) {"
html = html + "      var match = q == '' || tocItems[i].text.indexOf(q) >= 0;"
html = html + "      tocItems[i].el.style.display = match ? '' : 'none';"
html = html + "      tocItems[i].el.style.background = (match && q != '') ? '#37343a' : '';"
html = html + "    }"
html = html + "  };"
html = html + "}"

html = html + "var TEMPLATES = {};"
html = html + "function loadTplFile(path, name) {"
html = html + "  window.ipc.postMessage('OPEN\\n' + path);"
html = html + "}"

html = html + "function loadTpl(name) {"
html = html + "  var hasContent = document.getElementById('editor').value.trim().length > 0;"
html = html + "  if (hasContent && isDirty && !confirm('当前内容未保存，是否替换？')) return;"
html = html + "  document.getElementById('tplMenu').style.display = 'none';"
html = html + "  document.getElementById('status').textContent = '加载模板中: ' + name;"
html = html + "  var msg = 'TPL' + String.fromCharCode(10) + name;"
html = html + "  window.ipc.postMessage(msg);"
html = html + "}"

// 初始化
html = html + "window.onload = function() {"
html = html + "  toggleWrap(); toggleWrap();"
html = html + "  onEdit();"
html = html + "  setDirty(false);"
html = html + "  document.getElementById('editor').focus();"
html = html + "};"

html = html + "</script></html>"

// ---- 创建窗口 ----
var win = guiNewWindow("--title=Sflang 代码编辑器", "--width=1100", "--height=750")
win = guiSetHtml(win, html)
win = guiSetHandler(win, onMessage)

// 如果有命令行参数指定的文件，加载它
if initFile != "" && fileExists(initFile) {
    var initContent = readFile(initFile)
    // 延迟执行：在 guiShow 之前无法执行 guiEval，所以通过初始 HTML 内嵌
    // 改为在 HTML 的 onload 中检查全局变量
    // 简单方案：把初始内容编码到 HTML 中
    html = strReplace(html, "window.onload = function() {",
        "window.onload = function() { document.getElementById('editor').value = '" + escapeJS(initContent) + "'; document.getElementById('filename').textContent = '" + escapeJS(initFile) + "';")
    win = guiSetHtml(win, html)
}

guiShow(win)
