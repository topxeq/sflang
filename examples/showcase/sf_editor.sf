html = html + "  var overlay = document.createElement('div');"
html = html + "  overlay.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.6);z-index:1001;display:flex;align-items:center;justify-content:center;';"
html = html + "  var dlg = document.createElement('div');"
