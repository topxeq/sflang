// port of bitwise.char — 位运算

// byte 类型与位运算
b1 := byte(97)     // 'a'
b2 := byte(98)     // 'b'
b3 := b2            // byte 赋值直接拷贝

pl("b1: %v, b2: %v, b3: %v\n", b1, b2, b3)

// 位与
b4 := b3 & 0x0F
b5 := b3 & 0xF0

pl("b3 & 0x0F = %02x", b4)
pl("b3 & 0xF0 = %02x", b5)

// 整数位运算
pln("12 | 10 =", 12 | 10)    // 14
pln("12 ^ 10 =", 12 ^ 10)    // 6
pln("12 & 10 =", 12 & 10)    // 8
pln("~5 =", ~5)               // -6
pln("1 << 4 =", 1 << 4)      // 16
pln("256 >> 2 =", 256 >> 2)  // 64
