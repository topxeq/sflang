// port of copy.char — 值语义演示
// Sflang 字符串是不可变的（Arc<str>），赋值是拷贝

a := "abc"
b := a

pln(a, b)

a += "12"
pln(a, b)       // a 变了，b 不变（字符串不可变，+= 创建新串）

b += "de"
pln(a, b)       // b 变了，a 不变

// 数组是引用类型（共享）
c := [1, 2, 3]
d := c

c[0] = 99
pln(c, d)       // 都变了（数组是 Arc<Mutex> 共享）

// 对象也是引用类型
e := {x: 1}
f := e

e.x = 99
pln(e.x, f.x)   // 都变了
