// port of compile2.char — 动态编译执行带参数
// Sflang 的 compile/runCode 在当前全局环境中执行

sourceT := `
a := 1
r1 := a + 2.3
pl("r1=%v", r1)
pl("global x = %v", x)
return r1
`

// 先设置全局变量
x := 99

code := compile(sourceT)
result := runCode(code)
pln("result:", result)

// 动态生成并执行
for i := 0; i < 3; i++ {
    src := spr("return %d * 10", i)
    c := compile(src)
    pln("i=%d, result=%d", i, runCode(c))
}
