// port of ticker.char — 定时执行任务
// Charlang 用 runTicker(1.5, delegate)，Sflang 用 run + while + sleep 模拟

// 用数组传递可变参数
a1 := [0]
maxCount := 5

// 定时任务函数（在线程中运行，循环 + sleep）
func tickTask(state, limit) {
    while state[0] <= limit {
        pln("tick: now =", now(), " count =", state[0])
        state[0]++
        if state[0] <= limit {
            sleep(1.5)
        }
    }
    pln("达到上限，停止")
}

// 启动定时任务（在新线程中）
run tickTask(a1, maxCount)

// 主线程等待子线程完成（毫秒，10000ms = 10秒）
sleep(10)
pln("主线程退出")
