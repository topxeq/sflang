// port of orderedMap.char — 有序映射
// Sflang 用 map{} 字面量或 newMap()

map1 := map{"SSS": "v11", "k1": "v1", "a2": 1}

plt(map1)

// 有序遍历
pln("遍历（插入顺序）:")
for k, v in map1 {
    pl("  %s = %v\n", k, v)
}

// 添加新键
map1["3"] = "v3"
map1["newKey"] = [1, 2, 3]

pln("after add:")
for k, v in map1 {
    pl("  %s = %v\n", k, v)
}

// 删除（Sflang 暂不支持直接删除 map 键，可重建）
pln("len:", len(map1))
pln("hasKey SSS:", hasKey(map1, "SSS"))

// newMap() 创建空 map
m2 := newMap()
m2["a"] = 1
m2["b"] = 2
pln("newMap:", m2)
